---
import Project from '../components/Project.astro';
import Block from '../components/Block.astro';
import multilangSpliter from '../utils/multilangSpliter.js';

export interface Props extends BlockProps {}

const { lang = 'tw', className } = Astro.props;

const files = await Astro.glob('../content/projects/*.{md, mdx}');
const mds = multilangSpliter(files, lang, true);
---

<style>
  .content {
    display: flex;
    flex-direction: column;
  }
</style>
<Block header="Selected Projects" className={className}>
  <div class="content">
    {
      mds
        .sort(
          (mdA, mdB) =>
            (mdB.frontmatter.order ?? 0) - (mdA.frontmatter.order ?? 0),
        )
        .filter((md) => {
          const hide = md.frontmatter.display === false;
          return !hide;
        })
        .map(({ frontmatter, Content }) => {
          return (
            <Project
              title={frontmatter.title}
              link={frontmatter.link}
              repo={frontmatter.repo}
              links={frontmatter.links}
            >
              <Content />
            </Project>
          );
        })
    }
  </div>
</Block>
